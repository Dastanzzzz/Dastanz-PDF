{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Advanced AI-powered PDF Editor for editing, OCR, and document processing.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.dastanz.pdfeditor",
    "productName": "AI Dastanz PDF Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  },
  "keywords": [
    "pdf",
    "editor",
    "ai",
    "ocr"
  ],
  "author": "Dastanz",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
